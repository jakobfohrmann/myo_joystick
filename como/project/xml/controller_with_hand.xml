<?xml version="1.0"?>
<mujoco model="controller-hand-task">

    <!-- MyoHand Assets  -->
    <include file="../../myo_sim_repo/myo_sim/hand/assets/myohand_assets.xml"/>

    <compiler inertiafromgeom="auto" angle="radian" balanceinertia="true"
              boundmass="0.001" boundinertia=".0001"
              meshdir="../../myo_sim_repo/myo_sim"
              texturedir="../../myo_sim_repo/myo_sim"/>

    <option timestep="0.002" gravity="0 0 -9.81"/>

    <!-- Visual Settings -->
    <visual>
        <global offwidth="1920" offheight="1080"/>
    </visual>

    <!-- Assets -->
    <asset>
        <mesh name="controller" file="../../project/assets/simple_controller/xbox_controller.stl" scale="0.001 0.001 0.001"/>
        <mesh name="thumbstick" file="../../project/assets/simple_controller/thumb_stick.stl" scale="1 1 1"/>

        <!-- Materials -->
        <material name="mat_controller" rgba="0.95 0.95 0.95 1"/>
        <material name="mat_thumbstick"  rgba="0.95 0.95 0.95 1"/>
        <material name="mat_target_x" rgba="1.0 0.0 0.0 0.8"/>
        <material name="mat_target_y" rgba="0.0 1.0 0.0 0.8"/>
        <material name="mat_target_z" rgba="0.0 0.0 1.0 0.8"/>
    </asset>

    <worldbody>
        <!-- Lights -->
        <light name="main_light"
               directional="true"
               diffuse="2.0 2.0 2.0"
               specular="0.3 0.3 0.3"
               pos="0.6 0.2 2.0"
               dir="-0.3 -0.2 -1"/>
        <light name="top_light"
               pos="0 0 0.5"
               dir="0 0 -1"
               diffuse="1.5 1.5 1.5"
               specular="0.2 0.2 0.2"/>
        <light name="side_light_l"
               pos="0.3 0.3 0.3"
               dir="-1 -1 -1"
               diffuse="1.2 1.2 1.2"
               specular="0.2 0.2 0.2"/>
        <light name="side_light_r"
               pos="-0.3 0.3 0.3"
               dir="1 -1 -1"
               diffuse="1.2 1.2 1.2"
               specular="0.2 0.2 0.2"/>
        <light name="front_light"
               pos="0 0.3 0.2"
               dir="0 -1 0"
               diffuse="1.0 1.0 1.0"
               specular="0.1 0.1 0.1"/>

        <!-- Ground Plane -->
        <geom name="ground" type="plane" pos="0 0 0" size="2 2 0.1" rgba="0.2 0.2 0.2 1"/>

        <!-- Target Spheres -->
        <body name="target_x" pos="0.3 -0.2 0.5">
            <geom name="target_x_geom" type="sphere" size="0.05" material="mat_target_x"/>
        </body>

        <body name="target_y" pos="0.02 0.1 0.5">
            <geom name="target_y_geom" type="sphere" size="0.05" material="mat_target_y"/>
        </body>

        <body name="target_z" pos="0.02 -0.2 0.7">
            <geom name="target_z_geom" type="sphere" size="0.05" material="mat_target_z"/>
        </body>

        <!-- MyoHand  -->
        <include file="../../myo_sim_repo/myo_sim/hand/assets/myohand_body.xml"/>

        <!-- Controller Body  -->
        <body name="controller" pos="-0.145 -0.53 1.42" euler="-0.4363 0 3.14159">
            <geom name="controller_geom"
                  type="mesh"
                  mesh="controller"
                  material="mat_controller"
                  rgba="0.8 0.8 0.8 1"
                  contype="0"
                  conaffinity="0"/>
        </body>

        <!-- Thumbstick  -->
        <body name="thumbstick_base" pos="-0.158935 -0.526611 1.474471" euler="0 0  3.14159">
            <site name="thumbstick_marker" pos="0 0 0" size="0.001" rgba="0 1 0 1"/>

            <joint name="thumbstick_rx"
                   type="hinge"
                   axis="1 0 0"
                   pos="0 0 -0.025"
                   limited="true"
                   range="-0.35 0.35"
                   damping="0.2"/>

            <joint name="thumbstick_ry"
                   type="hinge"
                   axis="0 1 0"
                   pos="0 0 -0.025"
                   limited="true"
                   range="-0.35 0.35"
                   damping="0.2"/>

            <geom name="thumbstick_geom"
                  type="mesh"
                  mesh="thumbstick"
                  pos="0 0 -0.025"
                  material="mat_thumbstick"
                  rgba="0.2 0.2 0.2 1"
                  mass="0.1"
                  contype="0"
                  conaffinity="0"/>
        </body>

        <!-- Cameras -->
        <camera name="cam_overview_iso" mode="targetbody" target="thumbstick_base" pos="0.55 0.25 2.05" fovy="45"/>
        <camera name="cam_front_wide"   mode="targetbody" target="thumbstick_base" pos="-0.17 0.30 1.60" fovy="55"/>
        <camera name="cam_back_wide"    mode="targetbody" target="thumbstick_base" pos="-0.17 -1.45 1.60" fovy="55"/>
        <camera name="cam_top_down"     mode="targetbody" target="thumbstick_base" pos="-0.17 -0.53 2.75" fovy="35"/>
        <camera name="cam_thumb_close"  mode="targetbody" target="distal_thumb"    pos="-0.05 -0.35 1.60" fovy="30"/>
        <camera name="cam_joystick_top_close" mode="targetbody" target="thumbstick_base" pos="-0.168935 -0.526611 1.78" fovy="20"/>
        <camera name="cam_joystick_overhead_close" mode="targetbody" target="thumbstick_base" pos="-0.168935 -0.526611 1.57" fovy="18"/>

    </worldbody>

    <!-- Contact Rules -->
    <contact>
        <exclude body1="full_body" body2="controller"/>
        <exclude body1="full_body" body2="thumbstick_base"/>
    </contact>

    <!-- Equality constraints -->
    <equality>
        
        <!--<weld name="thumb_to_stick"
              site1="THtip"
              site2="thumbstick_marker"
              solref="0.02 1"
              solimp="0.95 0.95 0.01"/>-->

        <connect name="thumb_to_stick_connect"
             site1="THtip"
             site2="thumbstick_marker"
             solref="0.02 1"
             solimp="0.9 0.98 0.02"/>    

        
        <!-- Fix Non-Thumb Joints at Baseline Positions  -->
        
        <!-- Comment this out to use fixed hand option-->
        <joint joint1="pro_sup"   polycoef="0.246963 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>
        <joint joint1="deviation" polycoef="0.423677 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>
        <joint joint1="flexion"   polycoef="0.065393 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>


        <joint joint1="mcp2_flexion"    polycoef="0.000503 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>
        <joint joint1="mcp2_abduction"  polycoef="0.146684 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>
        <joint joint1="pm2_flexion"     polycoef="0.000086 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>
        <joint joint1="md2_flexion"     polycoef="0.000134 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>

        <joint joint1="mcp3_flexion"    polycoef="0.011450 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>
        <joint joint1="mcp3_abduction"  polycoef="0.023132 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>
        <joint joint1="pm3_flexion"     polycoef="0.000413 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>
        <joint joint1="md3_flexion"     polycoef="0.000201 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>

        <joint joint1="mcp4_flexion"    polycoef="0.019165 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>
        <joint joint1="mcp4_abduction"  polycoef="0.033831 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>
        <joint joint1="pm4_flexion"     polycoef="0.002169 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>
        <joint joint1="md4_flexion"     polycoef="0.001430 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>

        <joint joint1="mcp5_flexion"    polycoef="0.010210 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>
        <joint joint1="mcp5_abduction"  polycoef="-0.011778 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>
        <joint joint1="pm5_flexion"     polycoef="-0.000022 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/>
        <joint joint1="md5_flexion"     polycoef="0.001850 1 0 0 0" solimp="0.9999 0.9999 0.0001 0.5 2" solref="0.001 1"/> 
    </equality>

</mujoco>
