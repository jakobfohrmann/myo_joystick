<?xml version="1.0"?>
<mujoco model="controller-thumbstick-task">

    <!-- Compiler -->
    <compiler angle="radian"/>
    <option timestep="0.002" gravity="0 0 -9.81"/>

    <!-- Visual Settings -->
    <visual>
        <global offwidth="1920" offheight="1080"/>
    </visual>

    <!-- Assets -->
    <asset>
        <!-- Meshes -->
        <mesh name="controller" file="../assets/simple_controller/xbox_controller.stl" scale="0.001 0.001 0.001"/>
        <mesh name="thumbstick" file="../assets/simple_controller/thumb_stick.stl" scale="1 1 1"/>

        <!-- Materials -->
        <material name="mat_controller" rgba="0.95 0.95 0.95 1"/>
        <material name="mat_thumbstick"  rgba="0.95 0.95 0.95 1"/>
        <material name="mat_target" rgba="0 0.6 0.2 0.8"/>
    </asset>

    <worldbody>

        <!-- Lights -->
        <light name="main_light"
               type="directional"
               diffuse="2.0 2.0 2.0"
               specular="0.3 0.3 0.3"
               pos="0.6 0.2 2.0"
               dir="-0.3 -0.2 -1"/>
        <light name="top_light"
               pos="0 0 0.5"
               dir="0 0 -1"
               diffuse="1.5 1.5 1.5"
               specular="0.2 0.2 0.2"/>
        <light name="side_light_l"
               pos="0.3 0.3 0.3"
               dir="-1 -1 -1"
               diffuse="1.2 1.2 1.2"
               specular="0.2 0.2 0.2"/>
        <light name="side_light_r"
               pos="-0.3 0.3 0.3"
               dir="1 -1 -1"
               diffuse="1.2 1.2 1.2"
               specular="0.2 0.2 0.2"/>
        <light name="front_light"
               pos="0 0.3 0.2"
               dir="0 -1 0"
               diffuse="1.0 1.0 1.0"
               specular="0.1 0.1 0.1"/>

        <!-- Ground Plane -->
        <geom name="ground" type="plane" pos="0 0 0" size="2 2 0.1"
              rgba="0.2 0.2 0.2 1"/>

        <!-- Target Sphere -->
        <body name="target" pos="0.3 0.0 0.1">
            <geom name="target_geom" type="sphere" size="0.05" material="mat_target"/>
        </body>

        <!-- Controller Body -->
        <body name="controller" pos="0 0 0.2" euler="0 0 0">

            <!-- Cameras -->
            <camera name="cam_front" pos="0 1.0 0.6" euler="-0.4 0 3.14" fovy="70"/>
            <camera name="cam_back" pos="0 -1.0 0.6" euler="0.4 0 0" fovy="70"/>
            <camera name="cam_top" pos="0 0 1.3" euler="-1.57 0 0" fovy="70"/>
            <camera name="cam_left" pos="-1.0 0 0.5" euler="0 0.4 1.57" fovy="70"/>
            <camera name="cam_right" pos="1.0 0 0.5" euler="0 -0.4 -1.57" fovy="70"/>
            <camera name="cam_diag_front" pos="0.7 0.7 0.6" euler="-0.3 0.3 2.5" fovy="70"/>
            <camera name="cam_diag_back" pos="-0.7 -0.7 0.6" euler="0.3 -0.3 0.7" fovy="70"/>

            <geom name="controller_geom" 
                  type="mesh"
                  mesh="controller"
                  material="mat_controller"
                  rgba="0.8 0.8 0.8 1"/>

            <!-- Thumbstick  -->
            <body name="thumbstick_base" pos="-0.02 -0.01 0.02">

                <!-- X-Axis Rotation -->
                <joint name="thumbstick_rx"
                       type="hinge"
                       axis="1 0 0"
                       limited="true"
                       range="-0.35 0.35"
                       damping="0.2"/>

                <!-- Y-Axis Rotation -->
                <joint name="thumbstick_ry"
                       type="hinge"
                       axis="0 1 0"
                       limited="true"
                       range="-0.35 0.35"
                       damping="0.2"/>

                <!-- Invisible mass geom -->
                <geom name="thumbstick_mass" type="sphere" size="0.01" mass="0.01" rgba="0 0 0 0" contype="0" conaffinity="0"/>

                <!-- The Actual Stick -->
                <geom name="thumbstick_geom"
                      type="mesh"
                      mesh="thumbstick"
                      material="mat_thumbstick"
                      rgba="0.2 0.2 0.2 1"
                      mass="0.1"/>
            </body>

        </body>

    </worldbody>

    <contact/>

</mujoco>
